# Production-oriented defaults (Render: set these in the service Environment tab,
# or rely on deploy-rain-backend.cjs to inject RAIN_ENVIRONMENT + ARBITRUM_RPC_URL).
RAIN_ENVIRONMENT=production
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
PORT=10000
# Optional: comma-separated origins for browser CORS (leave unset to allow any origin).
# FRONTEND_URL=https://your-site.onrender.com
# DATABASE_URL is injected automatically when deploying via AgentBase.
# Required for POST /markets/ai-draft:
# GEMINI_API_KEY=
